# =============================================================================
# REQUIRED — minimum needed to run with default OpenAI provider
# =============================================================================
OPENAI_API_KEY=sk-your-openai-key-here

# ---- Neo4j connection (matches docker-compose.yml) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=demodemo123

# ---- Timezone for slot filtering (IANA tz name) ----
APP_TIMEZONE=Asia/Kolkata

# ---- Hospital API connection ----
HOSPITAL_API_URL=http://localhost:8001


# =============================================================================
# OPTIONAL — provider configuration (defaults shown, OpenAI used if unset)
# =============================================================================

# ---- Graphiti LLM provider (for graph extraction) ----
# Options: openai | anthropic | gemini | groq | ollama
# GRAPHITI_LLM_PROVIDER=openai
# GRAPHITI_LLM_MODEL=gpt-4o-mini
# GRAPHITI_LLM_BASE_URL=http://localhost:11434/v1   # needed for ollama
# GRAPHITI_LLM_API_KEY=                             # overrides provider default key

# ---- Graphiti embedder provider ----
# Options: openai | ollama | gemini | voyage | huggingface
# WARNING: changing provider/model also requires changing EMBEDDING_DIM and
#          rebuilding the Neo4j vector index (wipe graph + re-seed).
# GRAPHITI_EMBEDDER_PROVIDER=openai
# GRAPHITI_EMBEDDER_MODEL=text-embedding-3-small
# GRAPHITI_EMBEDDER_BASE_URL=http://localhost:11434/v1  # needed for ollama
# GRAPHITI_EMBEDDER_API_KEY=                            # overrides provider default key

# Embedding dimension — must match what's stored in the Neo4j vector index.
# Graphiti default (if unset) = 1024. Reference values:
#   text-embedding-3-small (OpenAI, truncated) = 1024 (Graphiti default)
#   nomic-embed-text (Ollama)                  = 768
#   voyage-3-lite                              = 512
#   text-embedding-004 (Gemini)                = 768
#   google/gemma-embedding-001 (HuggingFace)   = 1024 (MRL — any dim works)
#   nomic-ai/nomic-embed-text-v1 (HuggingFace) = 768
# EMBEDDING_DIM=1024

# ---- Provider-specific API keys (only needed for the chosen provider) ----
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=gsk_...

# ---- HuggingFace embedder ----
# Only used when GRAPHITI_EMBEDDER_PROVIDER=huggingface
# Requires: pip install sentence-transformers  (not in default deps — pulls in torch)
# GRAPHITI_EMBEDDER_MODEL=google/gemma-embedding-001
